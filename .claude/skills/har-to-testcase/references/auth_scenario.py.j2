from __future__ import annotations

import allure

from sisyphus_auto_flow.harness.base_test import BaseAPITest


@allure.epic("{{ epic | default('系统安全') }}")
@allure.feature("{{ feature | default('登录认证') }}")
class {{ class_name }}(BaseAPITest):
    """{{ scenario_description | default('登录认证完整场景。') }}"""

    @allure.story("正常登录")
    @allure.severity(allure.severity_level.BLOCKER)
    def test_01_login_with_valid_credentials_returns_token(self):
        """正常登录：使用合法账号密码，期望返回 token。"""
        response = self.request("POST", "{{ login_endpoint }}", json={
            "{{ username_field | default('username') }}": "{{ valid_username }}",
            "{{ password_field | default('password') }}": "{{ valid_password }}",
        })

        self.assert_status(response, 200)
        self.assert_json_field(response, "{{ token_path | default('$.data.token') }}", exists=True)

        # 保存 token
        token = self.extract_json(response, "{{ token_path | default('$.data.token') }}")
        self.save("auth_token", token)

    @allure.story("Token 验证")
    @allure.severity(allure.severity_level.CRITICAL)
    def test_02_access_protected_api_with_token_returns_200(self):
        """携带有效 token：访问受保护接口，期望 200。"""
        token = self.load("auth_token")

        response = self.request(
            "GET", "{{ protected_endpoint | default('/api/v1/users/me') }}",
            headers={"Authorization": f"Bearer {token}"},
        )

        self.assert_status(response, 200)
